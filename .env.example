# trade-core docker compose environment template.
# Copy to .env and adjust; every variable below is referenced as
# ${VAR:-default} by docker-compose.yml or the included docker-compose.raft.yml,
# so an empty .env keeps today's laptop-safe defaults.
#
# Variables marked CHANGE-ME are credentials/secrets and MUST be overridden
# in any deployment reachable by anyone but you.

# ---------------------------------------------------------------------------
# Observability (all services)
# ---------------------------------------------------------------------------
# Structured-log level: error | warn | info | debug (default info). Lower it to
# warn/error in production to silence steady-state chatter.
TC_LOG=info
# Emit a panic backtrace before the process aborts (panic="abort"). The
# structured panic hook also logs one ERROR line naming payload + location.
RUST_BACKTRACE=1
# Warn when a durability barrier (Raft WAL, application proof, result outbox,
# or standalone journal) takes at least this many milliseconds. Default 50.
TC_SLOW_FSYNC_WARN_MS=50

# ---------------------------------------------------------------------------
# Credentials and tokens (production: CHANGE-ME, use a secret manager)
# ---------------------------------------------------------------------------
# Admin API bearer token served by market-data.
TC_ADMIN_TOKEN=local-admin-token            # CHANGE-ME in production
# Demo trading-terminal credential; replace with real user authentication.
TC_TRADING_TOKEN=local-trading-token        # CHANGE-ME in production
# Shared token between market-data proxy and the order API.
TC_ORDER_API_TOKEN=local-order-api-token    # CHANGE-ME in production
# Root password for all mysql-order-* shards.
MYSQL_ROOT_PASSWORD=local-root-password     # CHANGE-ME in production

# Local MySQL shard sizing. Production typically assigns 60-75% of each
# dedicated database host's RAM to the buffer pool and calibrates redo capacity
# against checkpoint age and recovery-time targets.
TC_MYSQL_BUFFER_POOL_SIZE=64M
TC_MYSQL_LOG_BUFFER_SIZE=16M
TC_MYSQL_REDO_CAPACITY=256M
TC_MYSQL_MAX_CONNECTIONS=100

# ---------------------------------------------------------------------------
# Order API / Kafka pipeline (docker-compose.yml)
# ---------------------------------------------------------------------------
# Per-broker development resources. Raise only when the host has enough CPU
# and memory for all three brokers (for example 4 / 4G on a >= 32 GiB host).
TC_KAFKA_SMP=1
TC_KAFKA_MEMORY=384M
# Idle keep-alive connections from market-data to the order API.
TC_ORDER_API_MAX_IDLE_CONNECTIONS=32
# Categories per Raft group routing bucket. Do not change on a live system;
# production keeps category ownership in control-plane metadata instead.
TC_ORDER_CATEGORY_SIZE=1000
TC_ORDER_KAFKA_TOPIC_PREFIX=orders-v2-g
# Comma-separated bootstrap brokers. Point this at an external cluster when
# horizontally scaling beyond the three local development brokers.
TC_ORDER_KAFKA_BROKERS=redpanda:9092,redpanda-2:9092,redpanda-3:9092
# Order topics; raise to 16+ on production-sized Kafka clusters.
TC_ORDER_KAFKA_TOPIC_COUNT=4
# Laptop-safe default; production capacity tests use 64+.
TC_ORDER_KAFKA_PARTITIONS_PER_TOPIC=8
TC_ORDER_KAFKA_CONSUMERS=32
# Consumer counts are per process. Divide the desired cluster-wide total
# across worker replicas; ingress-only API replicas set all three counts to 0.
TC_ORDER_KAFKA_DB_CONSUMERS=32
# Keep close to the number of active Raft groups. Extra submitters contend on
# the same ordered groups and can reduce throughput.
TC_ORDER_KAFKA_MATCH_CONSUMERS=4
# Worker-only deployments keep the metrics/health HTTP listener but reject all
# order POST requests and skip ingress-only Kafka lag polling.
TC_ORDER_HTTP_INGRESS_ENABLED=true
TC_ORDER_KAFKA_DB_GROUP=trade-order-persist-v1
TC_ORDER_KAFKA_MATCH_GROUP=trade-order-match-v1
TC_EXECUTION_KAFKA_TOPIC=trade-executions-v1
# Partitions for the execution topic created by redpanda-init.
TC_EXECUTION_KAFKA_PARTITIONS=16
# Compacted cross-replica publisher watermarks. At least one partition per
# concurrently hot group avoids checkpoint head-of-line blocking.
TC_EXECUTION_CURSOR_TOPIC=trade-execution-outbox-cursors-v1
TC_EXECUTION_CURSOR_PARTITIONS=16
# Publish one shared follower/failover watermark per N result batches (and
# always at a segment tail). Lower reduces failover duplicates; higher reduces
# compacted-topic traffic.
TC_EXECUTION_CURSOR_EVERY_BATCHES=16
TC_EXECUTION_KAFKA_MYSQL_GROUP=trade-order-execution-mysql-v1
TC_EXECUTION_KAFKA_MYSQL_CONSUMERS=4
# Example: "12:4,99:5" pins hot categories to dedicated Raft groups.
TC_RAFT_CATEGORY_PINS=
# Must exceed normal metrics response and Raft ACK latency. The ACK timeout
# should remain above WAL fsync p99 to avoid retry storms during disk stalls.
TC_RAFT_LEADER_PROBE_TIMEOUT_MS=1000
TC_RAFT_MATCHER_IO_TIMEOUT_MS=5000
# Per-group bounded queue between Kafka consumers and the process-wide Raft
# forwarding worker. A full queue applies backpressure instead of spawning.
TC_RAFT_FORWARD_QUEUE=64
# Bump when category->topic routing changes (versioned route records).
TC_ORDER_KAFKA_ROUTE_VERSION=1
# Kafka producer batching. LZ4 normally improves throughput enough to offset
# its CPU cost; retest with "none" if network is not the bottleneck.
TC_ORDER_KAFKA_LINGER_MS=1
TC_ORDER_KAFKA_BATCH_MESSAGES=10000
TC_ORDER_KAFKA_COMPRESSION=lz4
TC_ORDER_KAFKA_QUEUE_KBYTES=1048576
# Consumer fetch aggregation shared by command-persist, matching and result-DB.
TC_KAFKA_FETCH_MIN_BYTES=1
TC_KAFKA_FETCH_WAIT_MS=10
TC_KAFKA_FETCH_MAX_BYTES=52428800
# Processing is idempotent, so asynchronous offset commits remove one broker
# RTT per batch; set false only when diagnosing commit/rebalance behavior.
TC_KAFKA_OFFSET_COMMIT_ASYNC=true
TC_ORDER_BATCH_SIZE=1000
TC_ORDER_BATCH_LINGER_MS=2
# Match-only consumer batching. Larger batches amortize Raft quorum WAL,
# matching WAL/outbox and application-watermark durability barriers.
TC_ORDER_MATCH_BATCH_SIZE=10000
TC_ORDER_MATCH_BATCH_LINGER_MS=2
# Bounded queues and cross-consumer coalescing for the process-wide, long-lived
# per-MySQL-shard workers. Avoids spawning O(shards*batches) transient threads.
TC_MYSQL_SHARD_QUEUE=64
TC_MYSQL_SHARD_COALESCE_JOBS=16
# Hard bound on commands accepted by Kafka but not yet durable in both MySQL
# and matching. Sized for an 8 GiB Docker Desktop VM; production computes it
# from measured bytes/command and node memory (see docs §3.2).
TC_ORDER_MAX_PIPELINE_BACKLOG=50000

# Database horizontal sharding. TC_ORDER_MYSQL_SHARD_URLS must contain exactly
# TC_DB_COUNT comma-separated URLs. Changing either routing dimension remaps
# order_id slots and therefore requires a versioned migration on live data.
TC_DB_COUNT=10
TC_TABLES_PER_DB=100
TC_SHARD_ROUTE_VERSION=1
# TC_ORDER_MYSQL_SHARD_URLS=mysql://user:password@db-0:3306/mysql,...

# ---------------------------------------------------------------------------
# Raft matching nodes (docker-compose.raft.yml, included by docker-compose.yml)
# ---------------------------------------------------------------------------
# Raft groups hosted by each raft-N container (local dev topology).
TC_RAFT_GROUPS=4
# Optional production placement local to one physical host. When present, the
# launcher starts only these replicas; format:
# group|local_node|id@host:port,id@host:port;group|local_node|...
# TC_RAFT_GROUP_PLACEMENTS=7|2|1@rack-a:7071,2@rack-b:7072,3@rack-c:7073
# Semicolon-separated groups; each group contains comma-separated
# proposal@metrics endpoints. Production injects the generated machine map.
# TC_RAFT_GROUP_MATCHERS=node-a:9001@node-a:9102,node-b:9001@node-b:9102,...
TC_MATCH_POOL_PER_ASSET=2
# Raft is the authoritative command WAL. Production matching nodes do not
# synchronously write per-asset or per-shard command journals.
# State snapshot interval; 0 disables snapshots but increases replay time.
TC_SNAPSHOT_EVERY_SECS=30
# Keep disabled until engine snapshot transfer/install is implemented.
TC_RAFT_COMPACT_APPLIED_THRESHOLD=0
TC_RAFT_TRANSPORT_QUEUE=8192
TC_RAFT_READY_MAX_APPLY_LAG=32
TC_RAFT_READY_MAX_OUTBOX_PENDING=10000
# Bounded per-group command-id retry window. Size from per-group peak command
# rate * maximum Kafka retry/replay seconds * safety factor.
TC_RAFT_DEDUP_MAX_IDS=1000000
TC_EXECUTION_OUTBOX_SYNC_EVERY=1
TC_EXECUTION_PUBLISH_BATCH=512
TC_EXECUTION_KAFKA_LINGER_MS=2
TC_EXECUTION_KAFKA_BATCH_MESSAGES=10000
TC_EXECUTION_KAFKA_COMPRESSION=lz4
TC_EXECUTION_KAFKA_QUEUE_KBYTES=1048576
TC_EXECUTION_KAFKA_DELIVERY_TIMEOUT_MS=5000
TC_EXECUTION_KAFKA_BROKERS=redpanda:9092,redpanda-2:9092,redpanda-3:9092
# Set false only when isolating Kafka -> Raft/WAL -> in-memory matching.
# The durable result outbox remains enabled; only its Kafka publisher stops.
TC_EXECUTION_PUBLISH_ENABLED=true
